<% if (title) { %>
  <h1><%= title %></h1>
<% } %>

<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
  <% errors.array().forEach(error => { %>
    <li><%= error.msg %></li>
  <% }) %>
  </ul>
<% } %>

<form class="account-form" action="/account/register" method="post">
  <fieldset>
    <label for="account_firstname">First name:</label>
    <input id="account_firstname" name="account_firstname" type="text" required>

    <label for="account_lastname">Last name:</label>
    <input id="account_lastname" name="account_lastname" type="text" required>

    <label for="account_email">Email address:</label>
    <input
      id="account_email"
      name="account_email"
      type="email"
      required
      placeholder="Enter a valid email address">

    <label for="account_password">Password:</label>
    <input
      id="account_password"
      name="account_password"
      type="password"
      required
      pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">

    <div class="account-form__rules">
      All fields are required. Password must be at least 12 characters long and contain at least 1 capital letter, 1 number, and 1 special character.
    </div>

    <button type="submit">Register</button>
  </fieldset>
</form>
