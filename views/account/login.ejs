<% if (title) { %>
  <h1><%= title %></h1>
<% } %>

<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
  <% errors.array().forEach(error => { %>
    <li><%= error.msg %></li>
  <% }) %>
  </ul>
<% } %>

<form id="loginForm" class="account-form" action="/account/login" method="post">
  <fieldset>
    <label for="account_email">Email:</label>
    <input
      id="account_email"
      name="account_email"
      type="email"
      required
      placeholder="Enter a valid email address"
      value="<%= locals.account_email %>">

    <label for="account_password">Password:</label>
    <input
      id="account_password"
      name="account_password"
      type="password"
      required
      pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">

    <div class="account-form__rules">
      Password must be at least 12 characters long and contain at least 1 capital letter, 1 number, and 1 special character.
    </div>

    <button type="submit">Login</button>
  </fieldset>

  <p class="account-form__hint">
    No account? <a href="/account/register">Sign-up</a>
  </p>
</form>
